# Telegram bot token from @BotFather (required)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Target chat or channel id, e.g. -1001234567890 or @your_channel (required)
TELEGRAM_CHAT_ID=-1001234567890

# Seconds between polls in loop mode (optional, default 600)
POLL_INTERVAL=600

# Where the seen-program state is stored (optional)
STATE_PATH=state/seen.json

# Per-request timeout in seconds (optional, default 30)
REQUEST_TIMEOUT=30

# Notify for already-existing programs on the first run (optional, default false).
# Leave false to record a baseline silently and only alert on future programs.
NOTIFY_EXISTING_ON_FIRST_RUN=false
